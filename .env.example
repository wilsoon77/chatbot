# ── App ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── LLM: selección de provider ───────────────────────
LLM_PROVIDER=api                    # "api" | "ollama"
LLM_API_PROVIDER=google             # "anthropic" | "openai" | "google" | "groq"

# Si LLM_API_PROVIDER=google:
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# Si LLM_API_PROVIDER=groq:
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Si LLM_API_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Si LLM_API_PROVIDER=openai (compatible con OpenAI, OpenRouter y Hugging Face):
# OPENAI_API_KEY=tu_api_key_o_token
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# Ejemplo OpenRouter:
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_MODEL=qwen/qwen-2.5-14b-instruct
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Ejemplo Hugging Face Serverless API:
# OPENAI_API_KEY=hf_...
# OPENAI_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct
# OPENAI_BASE_URL=https://router.huggingface.co/v1

# Si LLM_PROVIDER=ollama:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── WooCommerce de prueba ──────────────────
WOO_BASE_URL=https://tienda.com
WOO_CONSUMER_KEY=ck_...
WOO_CONSUMER_SECRET=cs_...

# ── Agentic loop ─────────────────────────────────────
MAX_TOOL_CALLS_PER_TURN=5

# ── Redis (Sprint 2) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

