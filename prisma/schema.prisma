generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]  // <- agregar esto

}

datasource db {
  provider = "postgresql"
 

}

model Tenant {
  id                String   @id @default(cuid())
  nombre            String
  systemPrompt      String  //ERES UN EXPERTO EN TECnologua
  woocommerceUrl    String
  consumerKey       String
  consumerSecret    String
  enabledTools      String[]
  redisTTL          Int      @default(3600)
  isActive          Boolean  @default(true) 

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  CLIENT
}