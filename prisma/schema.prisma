generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]  // <- agregar esto

}

datasource db {
  provider = "postgresql"

}

model Tenant {
  id                String   @id @default(cuid())
  nombre            String
  systemPrompt      String  //ERES UN EXPERTO EN TECnologua
  woocommerceUrl    String
  consumerKey       String
  consumerSecret    String
  enabledTools      String[]
  redisTTL          Int      @default(3600)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
